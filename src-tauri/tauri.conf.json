{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SiteWatcher",
  "version": "0.1.0",
  "identifier": "com.thatal.sitewatcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SiteWatcher Dashboard",
        "width": 950,
        "height": 680,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "popover",
        "title": "SiteWatcher Popover",
        "width": 360,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
